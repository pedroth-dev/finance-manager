# Database (create database finance_manager in PostgreSQL first)
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/finance_manager

# JWT (Etapa 2) — gere uma chave aleatória segura, por exemplo:
#   Python: python -c "import secrets; print(secrets.token_hex(32))"
#   Ou: openssl rand -hex 32
SECRET_KEY=generate-a-secure-random-key-here

# CORS - frontend dev server
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
